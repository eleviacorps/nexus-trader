NEXUS_ENV=production
NEXUS_HOST=0.0.0.0
NEXUS_PORT=8000
NEXUS_EXECUTION_MODE=manual_mode
NEXUS_FAIL_CLOSED=1
NEXUS_JUDGE_CACHE_ENABLED=1
NEXUS_JUDGE_CACHE_THRESHOLD=0.92
NEXUS_TRADEABILITY_THRESHOLD=0.62
NEXUS_RISK_PER_TRADE=0.0025
NEXUS_MAX_SIMULTANEOUS_TRADES=3
NEXUS_ALLOW_PYRAMIDING=0
NEXUS_SELL_STRICTER_THAN_BUY=1
NEXUS_MAX_CONSECUTIVE_LOSSES=5
NEXUS_MAX_ROLLING_DRAWDOWN=0.05
NEXUS_TRADER_INTERVAL_SECONDS=300
NEXUS_MONITOR_INTERVAL_SECONDS=600
NEXUS_BACKUP_INTERVAL_SECONDS=900
